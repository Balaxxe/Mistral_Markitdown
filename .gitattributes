# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Python
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf
*.pyd binary
*.pyo binary
*.pyc binary

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Configuration
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.flake8 text eol=lf
Makefile text eol=lf

# Document formats (binary)
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
*.rtf binary
*.epub binary
*.msg binary

# Image formats (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tiff binary
*.webp binary
*.avif binary
*.ico binary

# Audio formats (binary)
*.mp3 binary
*.wav binary
*.m4a binary
*.flac binary

# Archive formats (binary)
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Cursor config and hook files (LF required; prevents CRLF-induced hook
# failures on Windows and keeps hooks byte-identical across machines)
.cursor/hooks/*.js text eol=lf
.cursor/hooks.json text eol=lf
.cursor/rules/*.mdc text eol=lf
.cursor/skills/**/*.md text eol=lf
.cursor/agents/*.md text eol=lf
.cursor/environment.json text eol=lf
.cursorignore text eol=lf
.cursorindexingignore text eol=lf
